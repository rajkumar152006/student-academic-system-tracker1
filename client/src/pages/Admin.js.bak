import React, { useEffect, useState } from 'react';
import { useNavigate } from 'react-router-dom';
import axios from 'axios';

export default function Admin() {
  const [students, setStudents] = useState([]);
  const [selected, setSelected] = useState(null);
  const [editMode, setEditMode] = useState(false);
  const [editForm, setEditForm] = useState({});
  const [notificationCount, setNotificationCount] = useState(0);
  const [notifications, setNotifications] = useState([]);
  const [showNotificationDropdown, setShowNotificationDropdown] = useState(false);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');
  const [editingSubmission, setEditingSubmission] = useState({}); // Track local edits
  const navigate = useNavigate();

  // Check admin authentication
  useEffect(() => {
    const admin = localStorage.getItem('adminUser');
    if (!admin) navigate('/admin-login');
  }, [navigate]);

  // Fetch all students
  useEffect(() => {
    fetchStudents();
  }, []);

  // Fetch notifications
  useEffect(() => {
    fetchNotifications();
    const interval = setInterval(fetchNotifications, 3000); // Refresh every 3 seconds
    return () => clearInterval(interval);
  }, []);

  const fetchStudents = async () => {
    try {
      setLoading(true);
      setError('');
      const res = await axios.get('http://localhost:5000/api/students');
      setStudents(res.data || []);
    } catch (err) {
      console.error('Error fetching students:', err);
      setError('Failed to load students');
      setStudents([]);
    } finally {
      setLoading(false);
    }
  };

  const fetchNotifications = async () => {
    try {
      const res = await axios.get('http://localhost:5000/api/students/notifications/list');
      setNotifications(res.data || []);
      setNotificationCount(res.data?.length || 0);
    } catch (err) {
      console.error('Error fetching notifications:', err);
      setNotifications([]);
    }
  };

  const viewDetails = async (id) => {
    try {
      setLoading(true);
      setError('');
      const res = await axios.get(`http://localhost:5000/api/students/${id}`);
      if (!res.data) {
        setError('Student not found');
        return;
      }
      setSelected(res.data);
      setEditForm(JSON.parse(JSON.stringify(res.data)));
      setEditMode(false);
      setShowNotificationDropdown(false);
    } catch (err) {
      console.error('Error fetching student:', err);
      setError('Failed to load student details');
    } finally {
      setLoading(false);
    }
  };

  const handleNotificationClick = (notification) => {
    viewDetails(notification.studentId);
  };

  const handleEditChange = (field, value) => {
    setEditForm({ ...editForm, [field]: value });
  };

  const handleAddSubject = () => {
    const updated = { ...editForm };
    updated.subjects = updated.subjects || [];
    updated.subjects.push({ name: '', marks: 0, internal: 0 });
    setEditForm(updated);
  };

  const handleSubjectChange = (idx, key, value) => {
    const updated = { ...editForm };
    updated.subjects = updated.subjects || [];
    updated.subjects[idx] = { ...updated.subjects[idx], [key]: key === 'name' ? value : parseFloat(value || 0) };
    setEditForm(updated);
  };

  const handleRemoveSubject = (idx) => {
    const updated = { ...editForm };
    updated.subjects = (updated.subjects || []).filter((_, i) => i !== idx);
    setEditForm(updated);
  };

  const handleSaveEdit = async () => {
    try {
      setLoading(true);
      const res = await axios.put(`http://localhost:5000/api/students/${editForm._id}`, editForm);
      setSelected(res.data);
      setStudents(students.map(s => s._id === res.data._id ? res.data : s));
      setEditMode(false);
      setError('');
      alert('✅ Student updated successfully!');
    } catch (err) {
      console.error('Error saving:', err);
      setError(err.response?.data?.msg || err.message);
      alert('❌ Failed to update: ' + (err.response?.data?.msg || err.message));
    } finally {
      setLoading(false);
    }
  };

  const handleDeleteStudent = async () => {
    if (!window.confirm(`Delete ${selected.name}?`)) return;
    try {
      setLoading(true);
      await axios.delete(`http://localhost:5000/api/students/${selected._id}`);
      setStudents(students.filter(s => s._id !== selected._id));
      setSelected(null);
      alert('✅ Student deleted');
    } catch (err) {
      alert('❌ Delete failed: ' + err.message);
    } finally {
      setLoading(false);
    }
  };

  const handleUpdateSubmission = async (listName, idx, field, value) => {
    try {
      const updated = JSON.parse(JSON.stringify(selected));
      if (!updated[listName]?.[idx]) {
        setError('Item not found');
        return;
      }
      updated[listName][idx][field] = value;
      const res = await axios.put(`http://localhost:5000/api/students/${selected._id}`, updated);
      setSelected(res.data);
      setStudents(students.map(s => s._id === res.data._id ? res.data : s));
      // Refresh notifications after status change
      fetchNotifications();
      alert('✅ Submission ' + value);
    } catch (err) {
      console.error('Error updating:', err);
      setError(err.response?.data?.msg || err.message);
    }
  };

  const handleLogout = () => {
    localStorage.removeItem('adminUser');
    navigate('/admin-login');
  };

  const renderSubmissionItem = (listName, item, idx) => {
    const isApproved = item.status === 'approved';
    const isRejected = item.status === 'rejected';
    const isPending = item.status === 'pending';
    const bgColor = isPending ? '#fff8f3' : isApproved ? '#f0f8f4' : '#fef3f3';
    const borderColor = isPending ? '#f5576c' : isApproved ? '#28a745' : '#dc3545';
    
    // Get current editing values or fallback to item values
    const editKey = `${listName}-${idx}`;
    const currentMarks = editingSubmission[editKey]?.marks !== undefined ? editingSubmission[editKey].marks : item.marks || 0;
    const currentRemarks = editingSubmission[editKey]?.remarks !== undefined ? editingSubmission[editKey].remarks : item.remarks || '';
    const currentStatus = editingSubmission[editKey]?.status !== undefined ? editingSubmission[editKey].status : item.status || 'pending';

    return (
      <div key={`${listName}-${idx}`} style={{ background: bgColor, padding: 12, borderRadius: 8, border: `2px solid ${borderColor}` }}>
        <div style={{ display: 'flex', justifyContent: 'space-between', gap: 12, marginBottom: 12 }}>
          <div style={{ flex: 1 }}>
            <div style={{ fontWeight: 700 }}>{item.name}</div>
            <div style={{ fontSize: 12, color: '#7f8c8d', margin: '4px 0' }}>{item.description || item.role || item.conference || item.platform || 'N/A'}</div>
            <div style={{ fontSize: 11, marginTop: 4, color: '#999' }}>
              Status: <strong style={{ color: borderColor }}>{item.status || 'pending'}</strong>
            </div>
            {item.proof ?
              <a href={item.proof} target="_blank" rel="noreferrer" style={{ color: '#3b82f6', textDecoration: 'none', fontSize: 12, padding: '4px 8px', background: '#eff6ff', borderRadius: 4, display: 'inline-block', marginTop: 4 }}>
                📎 View Proof
              </a>
              : <span style={{ fontSize: 12, color: '#ccc' }}>No proof</span>
            }
          </div>
          <div style={{ minWidth: 240 }}>
            <div style={{ marginBottom: 8 }}>
              <label style={{ fontSize: 12, fontWeight: 600 }}>Marks</label>
              <input 
                type="number" 
                value={currentMarks} 
                onChange={e => setEditingSubmission({...editingSubmission, [editKey]: {...(editingSubmission[editKey] || {}), marks: parseFloat(e.target.value || 0)}})} 
                onBlur={e => handleUpdateSubmission(listName, idx, 'marks', parseFloat(e.target.value || 0))} 
                style={{ width: '100%', padding: 6, marginTop: 4, borderRadius: 4, border: '1px solid #ddd' }} 
              />
            </div>
            <div>
              <label style={{ fontSize: 12, fontWeight: 600 }}>Status</label>
              <select 
                value={currentStatus} 
                onChange={e => {setEditingSubmission({...editingSubmission, [editKey]: {...(editingSubmission[editKey] || {}), status: e.target.value}}); handleUpdateSubmission(listName, idx, 'status', e.target.value);}} 
                style={{ width: '100%', padding: 6, marginTop: 4, borderRadius: 4, border: '1px solid #ddd' }}>
                <option value="pending">Pending</option>
                <option value="approved">Approved</option>
                <option value="rejected">Rejected</option>
              </select>
            </div>
          </div>
        </div>

        {/* Remarks field - show for all statuses, emphasize for rejected */}
        <div style={{ background: isRejected ? '#fff3cd' : '#f7fafc', padding: 10, borderRadius: 6, border: `1px solid ${isRejected ? '#ffeaa7' : '#e8eef5'}` }}>
          <label style={{ fontSize: 12, fontWeight: 600, display: 'block', marginBottom: 4 }}>
            💬 {isRejected ? 'Rejection Remarks (Mandatory)' : 'Remarks'}
          </label>
          <textarea
            value={currentRemarks}
            onChange={e => setEditingSubmission({...editingSubmission, [editKey]: {...(editingSubmission[editKey] || {}), remarks: e.target.value}})}
            onBlur={e => handleUpdateSubmission(listName, idx, 'remarks', e.target.value)}
            placeholder={isRejected ? 'Explain why this submission was rejected...' : 'Add optional remarks...'}
            style={{
              width: '100%',
              padding: 8,
              borderRadius: 4,
              border: isRejected ? '2px solid #f5a623' : '1px solid #ddd',
              minHeight: 60,
              fontFamily: 'Arial, sans-serif',
              fontSize: 12,
              resize: 'vertical'
            }}
          />
        </div>
      </div>
    );
  };

  return (
    <div style={{ background: '#f5f7fa', minHeight: '100vh', padding: 20 }}>
      {/* Header with notification badge */}
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20 }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 15 }}>
          <h1 style={{ color: '#2c3e50', fontSize: 24, fontWeight: 700, margin: 0 }}>👨‍💼 Admin Dashboard</h1>
          <div style={{ position: 'relative' }}>
            <button
              onClick={() => setShowNotificationDropdown(!showNotificationDropdown)}
              style={{
                background: notificationCount > 0 ? '#f5576c' : '#ddd',
                color: notificationCount > 0 ? 'white' : '#999',
                border: 'none',
                padding: '8px 12px',
                borderRadius: 25,
                fontWeight: 700,
                fontSize: 14,
                cursor: 'pointer',
                minWidth: 50,
                textAlign: 'center',
                transition: 'all 0.2s'
              }}
              onMouseEnter={e => e.target.style.background = notificationCount > 0 ? '#d63447' : '#ccc'}
              onMouseLeave={e => e.target.style.background = notificationCount > 0 ? '#f5576c' : '#ddd'}
            >
              🔔 {notificationCount}
            </button>

            {/* Notification Dropdown */}
            {showNotificationDropdown && (
              <div style={{
                position: 'absolute',
                top: '100%',
                left: 0,
                background: 'white',
                border: '1px solid #e8eef5',
                borderRadius: 8,
                boxShadow: '0 4px 12px rgba(0,0,0,0.15)',
                zIndex: 1000,
                minWidth: 350,
                maxHeight: 400,
                overflowY: 'auto',
                marginTop: 8
              }}>
                {notifications.length > 0 ? (
                  <>
                    <div style={{ padding: 12, borderBottom: '1px solid #e8eef5', fontWeight: 600, color: '#2c3e50' }}>
                      📤 Pending Submissions ({notifications.length})
                    </div>
                    {notifications.map((notif, i) => (
                      <div
                        key={i}
                        onClick={() => handleNotificationClick(notif)}
                        style={{
                          padding: 12,
                          borderBottom: i < notifications.length - 1 ? '1px solid #f0f0f0' : 'none',
                          cursor: 'pointer',
                          background: '#fff',
                          transition: 'all 0.2s',
                          '&:hover': { background: '#f7fafc' }
                        }}
                        onMouseEnter={e => e.target.style.background = '#f7fafc'}
                        onMouseLeave={e => e.target.style.background = '#fff'}
                      >
                        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'start' }}>
                          <div style={{ flex: 1 }}>
                            <div style={{ fontWeight: 700, fontSize: 13 }}>{notif.rollNumber}</div>
                            <div style={{ fontSize: 12, color: '#7f8c8d', marginTop: 2 }}>{notif.studentName}</div>
                            <div style={{ fontSize: 11, color: '#999', marginTop: 4 }}>
                              <span style={{ background: '#fff3cd', color: '#856404', padding: '2px 6px', borderRadius: 3, marginRight: 6 }}>
                                {notif.submissionType}
                              </span>
                              <span style={{ color: '#7f8c8d' }}>{notif.title}</span>
                            </div>
                            <div style={{ fontSize: 10, color: '#bbb', marginTop: 4 }}>📅 {notif.date}</div>
                          </div>
                          <div style={{ background: '#f5576c', color: 'white', padding: '4px 8px', borderRadius: 4, fontSize: 11, fontWeight: 600, marginLeft: 8 }}>
                            PENDING
                          </div>
                        </div>
                      </div>
                    ))}
                  </>
                ) : (
                  <div style={{ padding: 20, textAlign: 'center', color: '#7f8c8d' }}>
                    ✅ No pending submissions
                  </div>
                )}
              </div>
            )}
          </div>
        </div>
        <button onClick={handleLogout} style={{ padding: '10px 16px', background: '#f5576c', color: 'white', border: 'none', borderRadius: 6, cursor: 'pointer', fontWeight: 600 }}>
          Logout
        </button>
      </div>

      {/* Error banner */}
      {error && (
        <div style={{ background: '#fee', color: '#c33', padding: 12, borderRadius: 6, marginBottom: 20, border: '1px solid #fcc' }}>
          ⚠️ {error}
        </div>
      )}

      {/* Loading indicator */}
      {loading && (
        <div style={{ textAlign: 'center', padding: 20, color: '#667eea', fontSize: 16 }}>
          ⏳ Loading...
        </div>
      )}

      {!loading && (
        <div style={{ display: 'grid', gridTemplateColumns: '1fr 2fr', gap: 20 }}>
          {/* Students list */}
          <div style={{ background: 'white', padding: 20, borderRadius: 10, boxShadow: '0 2px 8px rgba(0,0,0,0.1)' }}>
            <h3 style={{ color: '#2c3e50', marginTop: 0 }}>📚 Students ({students.length})</h3>
            <div style={{ display: 'grid', gap: 8, maxHeight: '70vh', overflowY: 'auto' }}>
              {students.length > 0 ? (
                students.map(s => {
                  const pendingCount =
                    (s.projectsList || []).filter(p => p.status === 'pending').length +
                    (s.internshipsList || []).filter(p => p.status === 'pending').length +
                    (s.hackathonsList || []).filter(p => p.status === 'pending').length +
                    (s.papersList || []).filter(p => p.status === 'pending').length +
                    (s.coursesList || []).filter(p => p.status === 'pending').length;
                  const isSelected = selected?._id === s._id;
                  return (
                    <div
                      key={s._id}
                      onClick={() => viewDetails(s._id)}
                      style={{
                        background: isSelected ? '#eff2ff' : 'white',
                        border: isSelected ? '2px solid #667eea' : '1px solid #e8eef5',
                        padding: 12,
                        borderRadius: 8,
                        cursor: 'pointer',
                        display: 'flex',
                        justifyContent: 'space-between',
                        alignItems: 'center'
                      }}
                    >
                      <div>
                        <div style={{ fontWeight: 700 }}>{s.name || 'N/A'}</div>
                        <div style={{ fontSize: 12, color: '#7f8c8d' }}>{s.rollNumber || 'N/A'}</div>
                      </div>
                      {pendingCount > 0 && (
                        <div style={{ background: '#fee', color: '#f5576c', padding: '4px 10px', borderRadius: 16, fontWeight: 700, fontSize: 12 }}>
                          {pendingCount}
                        </div>
                      )}
                    </div>
                  );
                })
              ) : (
                <div style={{ color: '#7f8c8d', padding: 20, textAlign: 'center' }}>No students</div>
              )}
            </div>
          </div>

          {/* Details panel */}
          <div style={{ background: 'white', padding: 20, borderRadius: 10, boxShadow: '0 2px 8px rgba(0,0,0,0.1)' }}>
            <h3 style={{ color: '#2c3e50', marginTop: 0 }}>📋 Details</h3>
            {selected ? (
              !editMode ? (
                <div style={{ maxHeight: '70vh', overflowY: 'auto' }}>
                  {/* Student Info */}
                  <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12, marginBottom: 20, padding: 12, background: '#f7fafc', borderRadius: 6 }}>
                    <div><strong>Name:</strong> {selected.name || 'N/A'}</div>
                    <div><strong>Roll:</strong> {selected.rollNumber || 'N/A'}</div>
                    <div><strong>Email:</strong> {selected.email || '-'}</div>
                    <div><strong>Department:</strong> {selected.department || 'N/A'}</div>
                    <div><strong>SGPA:</strong> {selected.sgpa ?? 'N/A'}</div>
                    <div><strong>CGPA:</strong> {selected.cgpa ?? 'N/A'}</div>
                  </div>

                  {/* Subjects */}
                  {(selected.subjects || []).length > 0 && (
                    <div style={{ marginBottom: 20 }}>
                      <h5 style={{ color: '#2c3e50', marginBottom: 8 }}>Subjects</h5>
                      <div style={{ display: 'grid', gap: 8 }}>
                        {selected.subjects.map((sub, i) => (
                          <div key={i} style={{ display: 'grid', gridTemplateColumns: '2fr 1fr 1fr', gap: 8, background: '#f7fafc', padding: 8, borderRadius: 6 }}>
                            <div><strong>{sub.name}</strong></div>
                            <div>Marks: {sub.marks || 0}</div>
                            <div>Internal: {sub.internal || 0}</div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {/* Submissions */}
                  {((selected.projectsList?.length) || (selected.internshipsList?.length) || (selected.hackathonsList?.length) || (selected.papersList?.length) || (selected.coursesList?.length)) > 0 ? (
                    <div>
                      <h5 style={{ color: '#2c3e50' }}>📤 Submissions</h5>
                      <div style={{ display: 'grid', gap: 10 }}>
                        {(selected.projectsList || []).map((item, i) => renderSubmissionItem('projectsList', item, i))}
                        {(selected.internshipsList || []).map((item, i) => renderSubmissionItem('internshipsList', item, i))}
                        {(selected.hackathonsList || []).map((item, i) => renderSubmissionItem('hackathonsList', item, i))}
                        {(selected.papersList || []).map((item, i) => renderSubmissionItem('papersList', item, i))}
                        {(selected.coursesList || []).map((item, i) => renderSubmissionItem('coursesList', item, i))}
                      </div>
                    </div>
                  ) : (
                    <div style={{ color: '#7f8c8d', padding: 20, textAlign: 'center' }}>No submissions</div>
                  )}

                  {/* Buttons */}
                  <div style={{ display: 'flex', gap: 10, marginTop: 20 }}>
                    <button onClick={() => setEditMode(true)} style={{ flex: 1, padding: 10, background: '#667eea', color: 'white', border: 'none', borderRadius: 6, fontWeight: 600, cursor: 'pointer' }}>
                      ✏️ Edit
                    </button>
                    <button onClick={handleDeleteStudent} style={{ flex: 1, padding: 10, background: '#f5576c', color: 'white', border: 'none', borderRadius: 6, fontWeight: 600, cursor: 'pointer' }}>
                      🗑️ Delete
                    </button>
                  </div>
                </div>
              ) : (
                <div style={{ maxHeight: '70vh', overflowY: 'auto' }}>
                  <h4>Edit Student</h4>
                  <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12, marginBottom: 20 }}>
                    <div>
                      <label style={{ display: 'block', marginBottom: 4, fontSize: 12, fontWeight: 600 }}>Name</label>
                      <input type="text" value={editForm.name || ''} onChange={e => handleEditChange('name', e.target.value)} style={{ width: '100%', padding: 8, border: '1px solid #ddd', borderRadius: 4 }} />
                    </div>
                    <div>
                      <label style={{ display: 'block', marginBottom: 4, fontSize: 12, fontWeight: 600 }}>Roll Number</label>
                      <input type="text" value={editForm.rollNumber || ''} onChange={e => handleEditChange('rollNumber', e.target.value)} style={{ width: '100%', padding: 8, border: '1px solid #ddd', borderRadius: 4 }} />
                    </div>
                    <div>
                      <label style={{ display: 'block', marginBottom: 4, fontSize: 12, fontWeight: 600 }}>Email</label>
                      <input type="email" value={editForm.email || ''} onChange={e => handleEditChange('email', e.target.value)} style={{ width: '100%', padding: 8, border: '1px solid #ddd', borderRadius: 4 }} />
                    </div>
                    <div>
                      <label style={{ display: 'block', marginBottom: 4, fontSize: 12, fontWeight: 600 }}>SGPA</label>
                      <input type="number" step="0.1" value={editForm.sgpa || 0} onChange={e => handleEditChange('sgpa', parseFloat(e.target.value))} style={{ width: '100%', padding: 8, border: '1px solid #ddd', borderRadius: 4 }} />
                    </div>
                    <div>
                      <label style={{ display: 'block', marginBottom: 4, fontSize: 12, fontWeight: 600 }}>CGPA</label>
                      <input type="number" step="0.1" value={editForm.cgpa || 0} onChange={e => handleEditChange('cgpa', parseFloat(e.target.value))} style={{ width: '100%', padding: 8, border: '1px solid #ddd', borderRadius: 4 }} />
                    </div>
                    <div>
                      <label style={{ display: 'block', marginBottom: 4, fontSize: 12, fontWeight: 600 }}>Year</label>
                      <input type="number" value={editForm.year || 0} onChange={e => handleEditChange('year', parseInt(e.target.value))} style={{ width: '100%', padding: 8, border: '1px solid #ddd', borderRadius: 4 }} />
                    </div>
                    <div>
                      <label style={{ display: 'block', marginBottom: 4, fontSize: 12, fontWeight: 600 }}>Fees Due (₹)</label>
                      <input type="number" value={editForm.feesDue || 0} onChange={e => handleEditChange('feesDue', parseFloat(e.target.value))} style={{ width: '100%', padding: 8, border: '1px solid #ddd', borderRadius: 4 }} />
                    </div>
                  </div>

                  <div style={{ marginBottom: 20 }}>
                    <h5>Subjects</h5>
                    {(editForm.subjects || []).map((sub, i) => (
                      <div key={i} style={{ display: 'grid', gridTemplateColumns: '2fr 1fr 1fr 50px', gap: 8, marginBottom: 8 }}>
                        <input value={sub.name || ''} onChange={e => handleSubjectChange(i, 'name', e.target.value)} placeholder="Subject name" style={{ padding: 8, border: '1px solid #ddd', borderRadius: 4 }} />
                        <input type="number" value={sub.marks || 0} onChange={e => handleSubjectChange(i, 'marks', e.target.value)} placeholder="Marks" style={{ padding: 8, border: '1px solid #ddd', borderRadius: 4 }} />
                        <input type="number" value={sub.internal || 0} onChange={e => handleSubjectChange(i, 'internal', e.target.value)} placeholder="Internal" style={{ padding: 8, border: '1px solid #ddd', borderRadius: 4 }} />
                        <button onClick={() => handleRemoveSubject(i)} style={{ background: '#f5576c', color: 'white', border: 'none', borderRadius: 4, cursor: 'pointer' }}>✕</button>
                      </div>
                    ))}
                    <button onClick={handleAddSubject} style={{ padding: '8px 12px', background: '#667eea', color: 'white', border: 'none', borderRadius: 4, cursor: 'pointer' }}>+ Add Subject</button>
                  </div>

                  <div style={{ display: 'flex', gap: 10 }}>
                    <button onClick={handleSaveEdit} style={{ flex: 1, padding: 10, background: '#28a745', color: 'white', border: 'none', borderRadius: 6, fontWeight: 600, cursor: 'pointer' }}>
                      💾 Save
                    </button>
                    <button onClick={() => setEditMode(false)} style={{ flex: 1, padding: 10, background: '#6c757d', color: 'white', border: 'none', borderRadius: 6, fontWeight: 600, cursor: 'pointer' }}>
                      ✕ Cancel
                    </button>
                  </div>
                </div>
              )
            ) : (
              <div style={{ color: '#7f8c8d', padding: 40, textAlign: 'center' }}>Select a student to view details</div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}
